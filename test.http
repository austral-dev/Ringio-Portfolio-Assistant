@baseUrl = http://localhost:1337/api/v1
@prodUrl = https://trabajo-integrador-tp2.onrender.com/api/v1

### Register
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
    "email": "test@test.com",
    "password": "123456"
}

### Login
# @name loginRequest
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "email": "test@test.com",
    "password": "123456"
}

### Ruta protegida
GET http://localhost:1337/health
Authorization: Bearer {{loginRequest.response.body.token}}

### Register PROD
POST {{prodUrl}}/auth/register
Content-Type: application/json

{
    "email": "test@test.com",
    "password": "123456"
}
### Login PROD
# @name loginRequest
POST {{prodUrl}}/auth/login
Content-Type: application/json

{
    "email": "test@test.com",
    "password": "123456"
}

### Chat con la IA
POST http://localhost:1337/api/v1/chat
Content-Type: application/json
Authorization: Bearer {{loginRequest.response.body.token}}

{
    "message": "¿Cuáles son las mejores criptomonedas para invertir a largo plazo?"
}


### Chat con mercado tradicional
POST http://localhost:1337/api/v1/chat
Content-Type: application/json
Authorization: Bearer {{loginRequest.response.body.token}}

{
    "message": "¿Cómo están las principales acciones del mercado hoy?"
}


### Pregunta fuera de tema
POST http://localhost:1337/api/v1/chat
Content-Type: application/json
Authorization: Bearer {{loginRequest.response.body.token}}

{
    "message": "¿Quién ganó el mundial 2022?"
}